DATABASE_URL="postgresql://user:password@db:5432/movie_shooting"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-me"
YANDEX_CLIENT_ID="replace-me"
YANDEX_CLIENT_SECRET="replace-me"
OWNER_EMAIL="you@example.com"
DEFAULT_STUDIO_TITLE="26 FPS"
ALLOW_STUDIO_CREATION="true"
UPLOAD_DIR="/app/uploads"
MAX_PDF_SIZE_MB="20"
VAPID_PUBLIC_KEY="replace-me"
VAPID_PRIVATE_KEY="replace-me"
VAPID_SUBJECT="mailto:you@example.com"

